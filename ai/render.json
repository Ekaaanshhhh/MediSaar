{
  "services": [
    {
      "type": "web",
      "name": "medisaar-ai",
      "runtime": "python",
      "pythonVersion": "3.11",
      "buildCommand": "pip install -r ai/requirements.txt",
      "startCommand": "cd ai && uvicorn api.main:app --host 0.0.0.0 --port $PORT",
      "envVars": [
        {
          "key": "PYTHONUNBUFFERED",
          "value": "true"
        },
        {
          "key": "ENVIRONMENT",
          "value": "production"
        },
        {
          "key": "DEBUG",
          "value": "false"
        }
      ],
      "repo": "https://github.com/Bhagwan01/MediSaar",
      "branch": "main"
    }
  ],
  "databases": [
    {
      "name": "medisaar-postgres",
      "plan": "free"
    }
  ]
}